{
  "name": "@vocabber/cli",
  "version": "0.1.0",
  "description": "JavaScript wrapper for the Vocabber Rust CLI.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "vocabbar": "./bin/vocabbar.js"
  },
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "bin/",
    "index.js"
  ],
  "optionalDependencies": {
    "@vocabber/cli-darwin-arm64": "workspace:*",
    "@vocabber/cli-darwin-x64": "workspace:*",
    "@vocabber/cli-linux-arm64": "workspace:*",
    "@vocabber/cli-linux-x64": "workspace:*",
    "@vocabber/cli-win32-x64": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}
