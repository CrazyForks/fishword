{
  "name": "@fishword/cli",
  "version": "0.1.0",
  "description": "JavaScript wrapper for the Fishword Rust CLI.",
  "type": "module",
  "license": "GPL-3.0-only",
  "bin": {
    "fishword": "./bin/fishword.js"
  },
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "bin/",
    "index.js"
  ],
  "optionalDependencies": {
    "@fishword/cli-darwin-arm64": "workspace:*",
    "@fishword/cli-darwin-x64": "workspace:*",
    "@fishword/cli-linux-arm64": "workspace:*",
    "@fishword/cli-linux-x64": "workspace:*",
    "@fishword/cli-win32-x64": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}
