{
  "name": "fishword-workspace",
  "version": "0.1.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build:rust": "cargo build --workspace",
    "dev:cli": "cargo build -p fishword-cli",
    "test:rust": "cargo test",
    "lint:rust": "cargo clippy --all-targets --all-features -- -D warnings",
    "format": "cargo fmt --all",
    "format:check": "cargo fmt --all -- --check",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "check:pi-extension": "tsc -p packages/pi-extension/tsconfig.json --noEmit",
    "check": "pnpm format && pnpm lint:rust && pnpm test:rust && pnpm smoke:cli"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
