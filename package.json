{
  "name": "fishword-workspace",
  "version": "0.1.3",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm run build:rust && pnpm run build:pi",
    "test": "pnpm run test:rust && pnpm run smoke:rust",
    "lint": "pnpm run lint:rust",
    "smoke": "pnpm run smoke:rust",
    "format": "pnpm run format:rust",
    "format:check": "pnpm run format:check:rust",
    "check": "pnpm run format:check && pnpm run lint && pnpm run test && pnpm run check:pi",
    "dev:rust": "cargo build -p fishword-cli",
    "build:rust": "cargo build --workspace",
    "test:rust": "cargo test",
    "lint:rust": "cargo clippy --all-targets --all-features -- -D warnings",
    "smoke:rust": "node scripts/smoke-cli.mjs",
    "format:rust": "cargo fmt --all",
    "format:check:rust": "cargo fmt --all -- --check",
    "dev:pi": "pnpm run build:pi && pi --extension ./packages/pi-extension/dist/index.js",
    "build:pi": "pnpm --filter @fishword/pi-extension run build",
    "check:pi": "pnpm --filter @fishword/pi-extension run check"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
