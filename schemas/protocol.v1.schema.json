{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fishword.local/schemas/protocol.v1.schema.json",
  "title": "Fishword CLI protocol v1",
  "oneOf": [
    { "$ref": "#/$defs/card_response" },
    { "$ref": "#/$defs/rate_response" },
    { "$ref": "#/$defs/decks_response" },
    { "$ref": "#/$defs/deck_use_response" },
    { "$ref": "#/$defs/card_list_response" },
    { "$ref": "#/$defs/status_response" },
    { "$ref": "#/$defs/stats_response" },
    { "$ref": "#/$defs/error_response" }
  ],
  "$defs": {
    "card_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "card", "display", "progress", "selection"],
      "properties": {
        "schema": {
          "enum": [
            "fishword.protocol.current.v1",
            "fishword.protocol.next.v1"
          ]
        },
        "card": { "$ref": "#/$defs/card" },
        "display": { "$ref": "#/$defs/display" },
        "progress": { "$ref": "#/$defs/progress" },
        "selection": { "$ref": "#/$defs/selection" }
      }
    },
    "rate_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "card", "display", "progress", "review", "next"],
      "properties": {
        "schema": { "const": "fishword.protocol.rate.v1" },
        "card": { "$ref": "#/$defs/card" },
        "display": { "$ref": "#/$defs/display" },
        "progress": { "$ref": "#/$defs/progress" },
        "review": { "$ref": "#/$defs/review" },
        "next": {
          "oneOf": [
            { "$ref": "#/$defs/card_response" },
            { "type": "null" }
          ]
        }
      }
    },
    "decks_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "decks"],
      "properties": {
        "schema": { "const": "fishword.protocol.decks.v1" },
        "decks": {
          "type": "array",
          "items": { "$ref": "#/$defs/deck_item" }
        }
      }
    },
    "deck_use_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "name", "message"],
      "properties": {
        "schema": { "const": "fishword.protocol.deck_use.v1" },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "message": { "type": "string" }
      }
    },
    "card_list_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "deck", "cards", "pagination"],
      "properties": {
        "schema": { "const": "fishword.protocol.card_list.v1" },
        "deck": { "$ref": "#/$defs/deck" },
        "cards": {
          "type": "array",
          "items": { "$ref": "#/$defs/card" }
        },
        "pagination": { "$ref": "#/$defs/pagination" }
      }
    },
    "status_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "deck", "mode", "today", "display", "next_action"],
      "properties": {
        "schema": { "const": "fishword.protocol.status.v1" },
        "deck": { "$ref": "#/$defs/deck" },
        "mode": { "enum": ["review", "complete", "empty"] },
        "today": {
          "type": "object",
          "additionalProperties": false,
          "required": ["due", "new_remaining", "reviewed"],
          "properties": {
            "due": { "type": "integer" },
            "new_remaining": { "type": "integer" },
            "reviewed": { "type": "integer" }
          }
        },
        "display": { "$ref": "#/$defs/status_display" },
        "next_action": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "label", "command"],
          "properties": {
            "kind": { "enum": ["review", "none"] },
            "label": { "type": "string" },
            "command": { "type": "string" }
          }
        }
      }
    },
    "stats_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "deck", "range", "summary", "series"],
      "properties": {
        "schema": { "const": "fishword.protocol.stats.v1" },
        "deck": { "$ref": "#/$defs/deck" },
        "range": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "days"],
          "properties": {
            "kind": { "const": "days" },
            "days": { "type": "integer" }
          }
        },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reviews", "reviewed_today", "good_or_easy_rate"],
          "properties": {
            "reviews": { "type": "integer" },
            "reviewed_today": { "type": "integer" },
            "good_or_easy_rate": { "type": ["number", "null"] }
          }
        },
        "series": {
          "type": "array",
          "items": { "$ref": "#/$defs/daily_stats" }
        }
      }
    },
    "error_response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "error"],
      "properties": {
        "schema": { "const": "fishword.protocol.error.v1" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          }
        }
      }
    },
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "db_id",
        "term",
        "language",
        "phonetic",
        "meanings",
        "deck",
        "tags",
        "source"
      ],
      "properties": {
        "id": { "type": "string" },
        "db_id": { "type": "integer" },
        "term": { "type": "string" },
        "language": { "type": "string" },
        "phonetic": {
          "type": "object",
          "additionalProperties": false,
          "required": ["us", "uk", "other"],
          "properties": {
            "us": { "type": ["string", "null"] },
            "uk": { "type": ["string", "null"] },
            "other": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "meanings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["part_of_speech", "definition"],
            "properties": {
              "part_of_speech": { "type": "string" },
              "definition": { "type": "string" },
              "example": { "type": "string" }
            }
          }
        },
        "deck": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "db_id"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "db_id": { "type": "integer" }
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "source": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["name", "license"],
          "properties": {
            "name": { "type": "string" },
            "license": { "type": ["string", "null"] }
          }
        }
      }
    },
    "deck_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "active"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "description": { "type": ["string", "null"] },
        "active": { "type": "boolean" }
      }
    },
    "pagination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "page_size",
        "total",
        "page_count",
        "has_previous",
        "has_next"
      ],
      "properties": {
        "page": { "type": "integer" },
        "page_size": { "type": "integer" },
        "total": { "type": "integer" },
        "page_count": { "type": "integer" },
        "has_previous": { "type": "boolean" },
        "has_next": { "type": "boolean" }
      }
    },
    "display": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plain", "compact", "status", "masked"],
      "properties": {
        "plain": { "type": "string" },
        "compact": { "type": "string" },
        "status": { "type": "string" },
        "masked": { "type": "string" }
      }
    },
    "status_display": {
      "type": "object",
      "additionalProperties": false,
      "required": ["plain", "compact", "statusline"],
      "properties": {
        "plain": { "type": "string" },
        "compact": { "type": "string" },
        "statusline": { "type": "string" }
      }
    },
    "daily_stats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "reviews",
        "again",
        "hard",
        "good",
        "easy",
        "good_or_easy_rate"
      ],
      "properties": {
        "date": { "type": "string" },
        "reviews": { "type": "integer" },
        "again": { "type": "integer" },
        "hard": { "type": "integer" },
        "good": { "type": "integer" },
        "easy": { "type": "integer" },
        "good_or_easy_rate": { "type": ["number", "null"] }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["due_count", "new_today_remaining", "reviewed_today"],
      "properties": {
        "due_count": { "type": "integer" },
        "new_today_remaining": { "type": "integer" },
        "reviewed_today": { "type": "integer" }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": {
        "reason": { "enum": ["due", "new"] }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rating",
        "due",
        "elapsed_days",
        "scheduled_days",
        "stability",
        "difficulty",
        "state"
      ],
      "properties": {
        "rating": { "enum": ["again", "hard", "good", "easy"] },
        "due": { "type": "string" },
        "elapsed_days": { "type": "integer" },
        "scheduled_days": { "type": "integer" },
        "stability": { "type": "number" },
        "difficulty": { "type": "number" },
        "state": { "enum": ["new", "learning", "review", "relearning"] }
      }
    }
  }
}
